dim(Default)
# Convert predicted probabilities into class predictions
# Start by classifying everyone as "No"
glm.pred <- rep("No", nrow(test_set))
library(ISLR2)
# Take a quick look at the data
head(Default)
dim(Default)
# Split the data into training and test sets
set.seed(7)
train_index <- sample(1:nrow(Default), nrow(Default) / 2, replace = FALSE)
train_set <- Default[train_index, ]
test_set  <- Default[-train_index, ]
# Fit logistic regression on the training data
glm.fit <- glm(default ~ student + balance, data = train_set, family = 'binomial')
# Model summary
summary(glm.fit)
# Fitted values from the training data:
# P(Y = 1 | X)
head(glm.fit$fitted.values)
head(train_set)
# Predicted probabilities for the test set:
# P(Y = 1 | X)
glm.prob <- predict(glm.fit, newdata = test_set, type = "response")
head(glm.prob)
head(test_set)
# These are predicted probabilities.
# We use contrasts() to check which category is coded as 1.
contrasts(Default$default)
# Since "Yes" is coded as 1, these probabilities are:
# P(default = "Yes" | X)
# Convert predicted probabilities into class predictions
# Start by classifying everyone as "No"
glm.pred <- rep("No", nrow(test_set))
# Use a cutoff of 0.2:
# if predicted probability > 0.2, classify as "Yes"
glm.pred[glm.prob > 0.2] <- "Yes"
# Confusion matrix
table(glm.pred, test_set$default)
# How to read confusion matrix
# rows = predicted class, columns = actual class
# Example:
#             Actual
#           No    Yes
# Pred No   50     10
# Pred Yes   5     35
#
# How to read this:
# - 50: predicted "No" and actually "No"  -> correct
# - 10: predicted "No" but actually "Yes" -> false negative (missed defaulter)
# - 5:  predicted "Yes" but actually "No" -> false positive
# - 35: predicted "Yes" and actually "Yes" -> correct
#
# In words:
# - Out of those predicted as "No", 50 truly did not default and 10 actually defaulted.
# - Out of those predicted as "Yes", 5 actually did not default and 35 truly defaulted.
# Overall misclassification rate
misclassification_rate <- 1- mean(glm.pred == test_set$default)
misclassification_rate
# glm.pred != test_set$default returns TRUE when the prediction is wrong
# mean(...) computes the proportion of wrong predictions
#
# Example:
# glm.pred        = "No"  "Yes"  "No"  "Yes"
# actual (true)   = "No"  "No"   "No"  "Yes"
## glm.pred == actual
#                   TRUE  FALSE  TRUE  TRUE
#
# 3 out of 4 are correct → accuracy = 3/4 = 0.75
# misclassification rate = 1 - 0.75 = 0.25
