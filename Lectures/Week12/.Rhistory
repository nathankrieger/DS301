library(ISLR2)
# Take a quick look at the data
head(Default)
dim(Default)
# Split the data into training and test sets
set.seed(7)
train_index <- sample(1:nrow(Default), nrow(Default) / 2, replace = FALSE)
train_set <- Default[train_index, ]
test_set  <- Default[-train_index, ]
# Fit logistic regression on the training data
glm.fit <- glm(default ~ student + balance, data = train_set, family = 'binomial')
# Model summary
summary(glm.fit)
# Fitted values from the training data:
# P(Y = 1 | X)
head(glm.fit$fitted.values)
head(train_set)
# Predicted probabilities for the test set:
# P(Y = 1 | X)
glm.prob <- predict(glm.fit, newdata = test_set, type = "response")
head(glm.prob)
head(test_set)
# These are predicted probabilities.
# We use contrasts() to check which category is coded as 1.
contrasts(Default$default)
# Since "Yes" is coded as 1, these probabilities are:
# P(default = "Yes" | X)
# Convert predicted probabilities into class predictions
# Start by classifying everyone as "No"
glm.pred <- rep("No", length(test_set))
# Use a cutoff of 0.2:
# if predicted probability > 0.2, classify as "Yes"
glm.pred[glm.prob > 0.2] <- "Yes"
# Confusion matrix
table(glm.pred, test_set$default)
# How to read confusion matrix
# rows = predicted class, columns = actual class
# Example:
#             Actual
#           No    Yes
# Pred No   50     10
# Pred Yes   5     35
#
# How to read this:
# - 50: predicted "No" and actually "No"  -> correct
# - 10: predicted "No" but actually "Yes" -> false negative (missed defaulter)
# - 5:  predicted "Yes" but actually "No" -> false positive
# - 35: predicted "Yes" and actually "Yes" -> correct
#
# In words:
# - Out of those predicted as "No", 50 truly did not default and 10 actually defaulted.
# - Out of those predicted as "Yes", 5 actually did not default and 35 truly defaulted.
# Overall misclassification rate
mean(glm.pred == test_set$default)
# glm.pred != test_set$default returns TRUE when the prediction is wrong
# mean(...) computes the proportion of wrong predictions
#
# Example:
# glm.pred        = "No"  "Yes"  "No"  "Yes"
# actual (true)   = "No"  "No"   "No"  "Yes"
## glm.pred == actual
#                   TRUE  FALSE  TRUE  TRUE
#
# 3 out of 4 are correct → accuracy = 3/4 = 0.75
# misclassification rate = 1 - 0.75 = 0.25
########################
## In-class Activity  ##
########################
## We'll continue with the logistic regression model above.
# (1) What is the misclassification rate of this model?
# Hint: Line 71,72
# (2) What is the misclassification rate if our classifier always predicts "No"?
# (3) Looking at OVERALL misclassification rate
# is not always the most meaningful thing,
# especially when the classes are highly unbalanced.
#
# In this context, which mistake is more costly for the bank?
# False negative or False positive
# False negative (more expensive):
# - We predict "No" (customer will NOT default)
# - But in reality, the customer DOES default
# → The bank may approve a loan or give credit
# → The customer fails to pay back → financial loss
#
# False positive (less expensive):
# - We predict "Yes" (customer WILL default)
# - But in reality, the customer does NOT default
# → The bank may reject a good customer
# → Lost opportunity, but no direct financial loss
# (4) Among individuals that actually defaulted (test_set$default == "Yes"),
# what is my misclassification rate (what proportion were predicted as "No"?)?
# Another way to compute part (4) using the confusion matrix
conf_mat <- table(glm.pred, test_set$default)
conf_mat
false_negative_rate <- conf_mat["No", "Yes"] / sum(conf_mat[, "Yes"])
false_negative_rate
# (5) Propose a way to reduce the misclassification rate among individuals
# that actually defaulted (Colunm "Yes"), without causing
# the overall misclassification rate to suffer too much.
# Hint: Look at line 45: glm.pred[glm.prob > 0.2] <- "Yes"
# Hint: If we lower the cutoff, will the model
#       predict "Yes" more often or less often?
# Do we want to increase or decrease cutoff (original value is 0.2)?
# (6) Based on your answer to (5), implement that approach here.
#
# Confusion matrix
table(glm.pred, test_set$default)
1- mean(glm.pred == test_set$default)
1- mean(glm.pred == test_set$default)
Default
