# Another way to compute part (4) using the confusion matrix
conf_mat <- table(glm.pred, test_set$default)
conf_mat
false_negative_rate <- conf_mat["No", "Yes"] / sum(conf_mat[, "Yes"])
false_negative_rate
# (5) Propose a way to reduce the misclassification rate among individuals
# that actually defaulted (Colunm "Yes"), without causing
