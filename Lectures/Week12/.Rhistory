misclass_rate < 1 - mean(glm.pred == test_set$default)
misclass_rate <- 1 - mean(glm.pred == test_set$default)
misclass_rate
# (2) What is the misclassification rate if our classifier always predicts "No"?
always_no <- rep("No", nrow(test_set))
always_no_misclass <- 1 - mean(always_no == test_set$default)
